{
  "manifest_version": 3,
  "name": "OPFS Viewer",
  "version": "1.0",
  "description": "Browse a site's Origin Private File System (OPFS) right from DevTools.",
  "minimum_chrome_version": "92",
  "devtools_page": "src/pages/devtools/devtools.html",
  "background": { "service_worker": "src/service-worker.js" },
  "permissions": ["scripting"],
  "host_permissions": ["<all_urls>"],
  "icons": {
    "16": "icons/16.png",
    "32": "icons/32.png",
    "48": "icons/48.png",
    "128": "icons/128.png"
  }
}
